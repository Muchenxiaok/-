def match_diagnosis(chief_complaint, present_illness, physical_exam, exams, past_history):
    """
    根据病历文本匹配最合适的诊断
    返回诊断名称及匹配得分
    """
    text = (chief_complaint + present_illness + physical_exam + exams + past_history).lower()
    vitals = extract_vitals_from_text(physical_exam)
    exam_keywords = extract_exam_keywords(exams)

    scores = {}
    for diag, rules in DIAGNOSIS_RULES.items():
        score = 0
        # 症状匹配
        if 'symptoms' in rules:
            symptom_matches = sum(1 for sym in rules['symptoms'] if sym in text)
            if symptom_matches >= rules.get('min_symptoms', 1):
                score += symptom_matches
        # 生命体征匹配
        if 'vitals' in rules:
            for vital, (low, high) in rules['vitals'].items():
                if vital in vitals and low <= vitals[vital] <= high:
                    score += 1
        # 检查结果匹配
        if 'exam_keywords' in rules:
            for kw in rules['exam_keywords']:
                if isinstance(kw, tuple):  # 数值型条件
                    key, low, high = kw
                    for ek in exam_keywords:
                        if isinstance(ek, tuple) and ek[0] == key and low <= ek[1] <= high:
                            score += 1
                            break
                else:  # 字符串关键词
                    if kw in text:
                        score += 1
        # 既往史匹配
        if 'past_history' in rules:
            for ph in rules['past_history']:
                if ph in text:
                    score += 1

        if score > 0:
            scores[diag] = score * rules.get('weight', 1.0)

    if scores:
        best = max(scores, key=scores.get)
        return best, scores[best]
    else:
        return random.choice(DIAGNOSES), 0


