AREA_CODES = [
    "110101", "310101", "440301", "510101", "420101",
    "330101", "320501", "120101", "500101", "210101"
]


def generate_id_card():
    area = random.choice(AREA_CODES)
    year = random.randint(1950, 2020)
    month = random.randint(1, 12)
    if month == 2:
        day = random.randint(1, 28)
    elif month in [4, 6, 9, 11]:
        day = random.randint(1, 30)
    else:
        day = random.randint(1, 31)
    birth = f"{year:04d}{month:02d}{day:02d}"
    seq = f"{random.randint(0, 999):03d}"
    body = area + birth + seq
    weights = [7, 9, 10, 5, 8, 4, 2, 1, 6, 3, 7, 9, 10, 5, 8, 4, 2]
    check_codes = "10X98765432"
    total = sum(int(body[i]) * weights[i] for i in range(17))
    check = check_codes[total % 11]
    return body + check


