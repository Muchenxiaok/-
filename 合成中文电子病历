def generate_fake_emr_with_logic(patient_id, start_date, end_date, random_diagnosis_rate=0.2):
    """
    生成一条完整的电子病历，诊断与文本内容逻辑关联
    random_diagnosis_rate: 随机诊断的比例（增加数据多样性）
    """
    chief = generate_chief_complaint()
    present = generate_present_illness()
    past = generate_past_history()
    physical = generate_physical_exam()
    exams = generate_exams()

    if random.random() < random_diagnosis_rate:
        diagnosis = random.choice(DIAGNOSES)
    else:
        diagnosis, _ = match_diagnosis(chief, present, physical, exams, past)

    treatment = generate_treatment_with_diagnosis(diagnosis)

    return {
        "patient_id": patient_id,
        "name": generate_name(),
        "id_card": generate_id_card(),
        "phone": generate_phone(),
        "insurance": generate_insurance(),
        "age": random_choice(AGES),
        "gender": random_choice(GENDERS),
        "chief_complaint": chief,
        "present_illness": present,
        "past_history": past,
        "physical_exam": physical,
        "exams": exams,
        "diagnosis": diagnosis,
        "treatment": treatment,
        "visit_time": generate_visit_time(start_date, end_date).strftime("%Y-%m-%d %H:%M:%S"),
    }


def main():
    start_date = datetime(2025, 4, 1)
    end_date = datetime(2026, 3, 31)
    total_records = 50000
    random_diagnosis_rate = 0.2  # 20% 随机诊断，增加真实感

    fieldnames = [
        "patient_id", "name", "id_card", "phone", "insurance",
        "age", "gender", "chief_complaint", "present_illness",
        "past_history", "physical_exam", "exams", "diagnosis",
        "treatment", "visit_time"
    ]

    output_file = "fake_emr_50000.csv"
    with open(output_file, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        for i in range(total_records):
            pid = f"P{i + 1:06d}"
            row = generate_fake_emr_with_logic(pid, start_date, end_date, random_diagnosis_rate)
            writer.writerow(row)
            if (i + 1) % 1000 == 0:
                print(f"已生成 {i + 1} 条记录...")
    print(f"生成完成！文件：{output_file}")


if __name__ == "__main__":
    main()
