def generate_visit_time(start_date, end_date):
    delta = end_date - start_date
    random_days = random.randint(0, delta.days)
    random_seconds = random.randint(0, 86400)
    return start_date + timedelta(days=random_days, seconds=random_seconds)


# ===================== 诊断规则匹配 =====================
def extract_vitals_from_text(physical_exam):
    """从体格检查文本中提取生命体征数值"""
    vitals = {}
    t_match = re.search(r'T\s*([\d.]+)', physical_exam)
    if t_match:
        vitals['temperature'] = float(t_match.group(1))
    p_match = re.search(r'P\s*(\d+)', physical_exam)
    if p_match:
        vitals['pulse'] = int(p_match.group(1))
    r_match = re.search(r'R\s*(\d+)', physical_exam)
    if r_match:
        vitals['respiratory'] = int(r_match.group(1))
    bp_match = re.search(r'BP\s*(\d+)/(\d+)', physical_exam)
    if bp_match:
        vitals['systolic_bp'] = int(bp_match.group(1))
        vitals['diastolic_bp'] = int(bp_match.group(2))
    return vitals


def extract_exam_keywords(exams):
    """从辅助检查中提取关键词，例如血糖、CT 表现等"""
    keywords = []
    # 血糖
    glu_match = re.search(r'血糖[：:]\s*([\d.]+)', exams)
    if glu_match:
        glu = float(glu_match.group(1))
        keywords.append(('glucose', glu))
    # 尿酸
    ua_match = re.search(r'尿酸[：:]\s*(\d+)', exams)
    if ua_match:
        keywords.append(('uric_acid', int(ua_match.group(1))))
    # 甲状腺功能
    tsh_match = re.search(r'TSH[：:]\s*([\d.]+)', exams)
    if tsh_match:
        keywords.append(('TSH', float(tsh_match.group(1))))
    ft3_match = re.search(r'FT3[：:]\s*([\d.]+)', exams)
    if ft3_match:
        keywords.append(('FT3', float(ft3_match.group(1))))
    # 肝功
    alt_match = re.search(r'ALT\s*(\d+)', exams)
    if alt_match:
        keywords.append(('ALT', int(alt_match.group(1))))
    # 血常规
    hb_match = re.search(r'Hb\s*(\d+)', exams)
    if hb_match:
        keywords.append(('hemoglobin', int(hb_match.group(1))))
    # 血脂
    chol_match = re.search(r'总胆固醇[：:]\s*([\d.]+)', exams)
    if chol_match:
        keywords.append(('cholesterol', float(chol_match.group(1))))
    tg_match = re.search(r'甘油三酯[：:]\s*([\d.]+)', exams)
    if tg_match:
        keywords.append(('triglyceride', float(tg_match.group(1))))
    # 影像学关键词
    if '肺纹理增粗' in exams or '湿啰音' in exams:
        keywords.append('lung_infiltration')
    if '结节' in exams:
        keywords.append('nodule')
    if 'ST-T改变' in exams or '心律失常' in exams:
        keywords.append('ecg_abnormal')
    if 'B超见胆囊结石' in exams:
        keywords.append('gallstone')
    if 'B超见肾结石' in exams:
        keywords.append('kidney_stone')
    return keywords


